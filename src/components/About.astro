---
// BASE_URL may or may not carry a trailing slash depending on config; normalize.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const avatar = `${base}/avatar.png`;

const facts = [
  { icon: 'pin', text: 'Uruguay' },
  { icon: 'briefcase', text: 'BOZ IT Staffing -> Intermex Wire Transfer' },
  { icon: 'badge', text: 'Software Testing Specialist' },
  { icon: 'github', text: 'github.com/santisanchez4', href: 'https://github.com/santisanchez4' },
];
---

<section id="about" class="section">
  <div class="container">
    <h2 class="section-label">About</h2>

    <div class="about-grid">
      <div class="about-text">
        <p>
          I'm a QA Manual &amp; Automation Engineer with 4+ years of experience, currently working
          at BOZ IT Staffing assigned to Intermex Wire Transfer - a leading fintech for
          international remittances.
        </p>
        <p>
          I specialize in end-to-end test automation using Playwright and TypeScript, REST API
          testing with Postman, and CI/CD pipeline management in Azure DevOps.
        </p>
        <p>
          I'm passionate about building maintainable test frameworks that genuinely improve team
          confidence in deployments.
        </p>
        <p>
          Beyond the day job, I develop personal projects in web and gaming tech, including a
          tournament platform for the LATAM Warzone community.
        </p>
      </div>

      <div class="about-side">
        <div class="photo-wrapper">
          <img
            class="about-photo"
            src={avatar}
            alt="Portrait of Santiago Sanchez"
            width="260"
            height="260"
            loading="lazy"
            decoding="async"
          />
        </div>

        <aside class="about-facts" aria-label="Key facts">
          <ul>
            {facts.map((fact) => (
              <li>
                <span class="fact-icon" aria-hidden="true">
                  {fact.icon === 'pin' && (
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                      <circle cx="12" cy="10" r="3" />
                    </svg>
                  )}
                  {fact.icon === 'briefcase' && (
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="2" y="7" width="20" height="14" rx="2" />
                      <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
                    </svg>
                  )}
                  {fact.icon === 'badge' && (
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 2 15 8l7 .9-5 4.8 1.2 6.8L12 17.3 5.8 20.5 7 13.7 2 8.9 9 8l3-6Z" />
                    </svg>
                  )}
                  {fact.icon === 'github' && (
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.02c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.34-5.47-5.95 0-1.31.47-2.39 1.24-3.23-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.92 1.23 3.23 0 4.62-2.81 5.64-5.49 5.94.43.37.82 1.1.82 2.22v3.29c0 .32.21.7.83.58A12 12 0 0 0 12 .5Z" />
                    </svg>
                  )}
                </span>
                {fact.href ? (
                  <a class="fact-text" href={fact.href} target="_blank" rel="noopener noreferrer">
                    {fact.text}
                  </a>
                ) : (
                  <span class="fact-text">{fact.text}</span>
                )}
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 36px;
  }

  .about-text p + p {
    margin-top: 16px;
  }

  .about-text p {
    max-width: 58ch;
    color: var(--color-text);
  }

  .about-side {
    display: flex;
    flex-direction: column;
    gap: 18px;
    align-items: center;
  }

  .photo-wrapper {
    width: 100%;
    max-width: 224px;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 28px;
  }

  .about-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 38%;
    transform: scale(1.12);
  }

  .about-facts {
    width: 100%;
    max-width: 320px;
    padding-top: 2px;
  }

  .about-facts ul {
    display: flex;
    flex-direction: column;
    gap: 11px;
  }

  .about-facts li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    line-height: 1.45;
    color: var(--color-text);
  }

  .fact-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 999px;
  }

  .fact-text {
    min-width: 0;
    color: var(--color-text);
  }

  a.fact-text {
    color: var(--color-text-muted);
    transition: color 0.18s ease;
  }

  a.fact-text:hover {
    color: var(--color-text);
  }

  @media (min-width: 768px) {
    .about-grid {
      grid-template-columns: 60fr 40fr;
      gap: 48px;
      align-items: start;
    }

    .about-side {
      align-items: flex-end;
      padding-top: 4px;
    }
  }
</style>
