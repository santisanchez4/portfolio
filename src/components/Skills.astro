---
// Brand icons (Simple Icons, monochrome) self-hosted in public/icons/skills/.
// LambdaTest has no Simple Icons icon in any version, so it falls back to a text monogram below.
// BASE_URL may or may not carry a trailing slash depending on config — normalize.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const iconBase = `${base}/icons/skills`;

const groups = [
  {
    title: 'Languages',
    skills: [
      { name: 'TypeScript', slug: 'typescript' },
      { name: 'Java', slug: 'java' },
    ],
  },
  {
    title: 'Frameworks',
    skills: [
      { name: 'Playwright', slug: 'playwright' },
      { name: 'Selenium', slug: 'selenium' },
      { name: 'JUnit 5', slug: 'junit5' },
      { name: 'Maven', slug: 'apachemaven' },
    ],
  },
  {
    title: 'API & Performance',
    skills: [
      { name: 'Postman', slug: 'postman' },
      { name: 'k6', slug: 'k6' },
    ],
  },
  {
    title: 'Platforms & CI/CD',
    skills: [
      { name: 'SQL Server', slug: 'microsoftsqlserver' },
      { name: 'Azure DevOps', slug: 'azuredevops' },
      { name: 'GitHub', slug: 'github' },
    ],
  },
  {
    title: 'Mobile Testing',
    skills: [
      { name: 'Appium', slug: 'appium' },
      { name: 'LambdaTest', slug: null, mono: 'LT' },
    ],
  },
  {
    title: 'AI Tools',
    skills: [
      { name: 'Claude', slug: 'anthropic' },
      { name: 'OpenAI', slug: 'openai' },
      { name: 'Gemini', slug: 'googlegemini' },
      { name: 'DeepSeek', slug: 'deepseek' },
    ],
  },
];
---

<section id="skills" class="section">
  <div class="container">
    <h2 class="section-label">Skills</h2>

    <div class="skill-groups">
      {groups.map((group) => (
        <div class="skill-group">
          <h3 class="skill-group-label">{group.title}</h3>
          <div class="skill-grid">
            {group.skills.map((skill) => (
              <div class="skill-item">
                {skill.slug ? (
                  <img
                    class="skill-logo"
                    src={`${iconBase}/${skill.slug}.svg`}
                    alt=""
                    width="28"
                    height="28"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <span class="skill-logo skill-logo-fallback" aria-hidden="true">{skill.mono}</span>
                )}
                <span class="skill-name">{skill.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skill-groups {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .skill-group-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 12px;
  }

  .skill-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 12px;
  }

  .skill-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 16px 12px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-align: center;
    transition: background 0.18s ease;
  }

  .skill-item:hover {
    background: var(--color-bg-subtle);
  }

  .skill-logo {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  /* Text-monogram fallback for skills without a Simple Icons brand icon */
  .skill-logo-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
    background: var(--color-tag-bg);
    border-radius: var(--radius-sm);
  }

  .skill-name {
    font-size: 12px;
    line-height: 1.2;
    color: var(--color-text);
  }
</style>
